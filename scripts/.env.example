# Deployment Secrets
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# GitHub Personal Access Token (for cloning private repos)
GH_TOKEN=your_github_token_here

# Docker Hub credentials
DOCKER_USER=abdulbakitopcu
DOCKER_TOKEN=your_docker_token_here

# Orchestrator connection (fill after deploying Orchestrator)
ORCH_HOST=
ORCH_PORT=50051

# CUA all-in-one defaults
CUA_IMAGE=abdulbakitopcu/cua-allinone:latest
CUA_MODEL_ID=Qwen/Qwen3.5-9B
CUA_MAX_MODEL_LEN=32768
CUA_TENSOR_PARALLEL_SIZE=1
CUA_GPU_MEMORY_UTILIZATION=0.92
